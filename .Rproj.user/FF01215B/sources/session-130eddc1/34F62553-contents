library(flexdashboard)
library(tidyverse)
library(plotly)
library(crosstalk)
library(DT)
library(janitor)
library(stringr)

# Load data
flchw <- read_csv("FLHCW_cleaned.csv") 

# Clean and prep variables
flchw <- flchw %>%
  mutate(
    yrs_experience = factor(yrs_experience, 
                            levels = c("1-5", "6-10", ">10")),
    daily_hh = factor(daily_hh, 
                      levels = c("0-5", "6-10", "11-20", "20+")),
    education_group = factor(education_lvl,
                             levels = c(1, 2, 3),
                             labels = c("Basic", "Intermediate", "Advanced")),
    digital_access = ifelse(
      access_smartphone == 1 |
        access_computer_laptop == 1 |
        access_internet_connection == 1,
      1, 0
    ),
    ict_tasks = rowSums(select(., contains("ict_")), na.rm = TRUE),
    # Digital readiness
    digitally_ready = ifelse(
      digital_access == 1 &
        ict_tasks >= 2 &
        interest_improving == 1,
      1, 0
    ),
    digitally_ready = factor(digitally_ready,
                             levels = c(0,1),
                             labels = c("Not Ready", "Ready"))
  )
shared_flchw <- SharedData$new(flchw)
filtered_data <- reactive({
  shared_flchw$data(withSelection = TRUE)
})

