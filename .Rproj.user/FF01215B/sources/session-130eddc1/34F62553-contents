# Factors Associated to Digital Readiness

renderDT({
  # Get live filtered data
  df_table <- shared_flchw$data(withSelection = TRUE)
  total_n <- nrow(df_table)
  
  # Ensure 'Ready' is the first column
  df_table$digitally_ready <- factor(df_table$digitally_ready, levels = c("Ready", "Not Ready"))
  
  if (total_n == 0) return(NULL)
  
  # Missing data calculation
  ict_cols <- names(df_table)[grep("ict_", names(df_table))]
  n_missing_ict <- sum(rowSums(is.na(df_table[, grep("ict_", names(df_table))])) == 6)
  # Helper function for bivariate rows
  get_bivariate_row <- function(data, col_name, label, is_binary = FALSE) {
    p_val_text <- "N/A"
    try({
      tab <- table(data[[col_name]], data$digitally_ready)
      if(nrow(tab) > 1 && ncol(tab) > 1) {
        p_val <- fisher.test(tab, simulate.p.value = TRUE)$p.value
        p_val_text <- ifelse(p_val < 0.0001, "< 0.0001", sprintf("%.4f", p_val))
      }
    }, silent = TRUE)
    
    header <- data.frame(
      Characteristic = paste0("<b>", label, "</b>"),
      Ready = "", Not_Ready = "", P_Value = p_val_text,
      stringsAsFactors = FALSE
    )
    
    if(is_binary) {
      unique_vals <- c(1, 0)
      labels_map <- c("1" = "Any", "0" = "None")
    } else {
      unique_vals <- if(is.factor(data[[col_name]])) levels(data[[col_name]]) else sort(unique(na.omit(data[[col_name]])))
      labels_map <- NULL
    }
    
    details <- map_df(unique_vals, function(v) {
      cat_data <- data[data[[col_name]] == v & !is.na(data[[col_name]]), ]
      n_cat_total <- nrow(cat_data)
      n_r <- sum(cat_data$digitally_ready == "Ready", na.rm = TRUE)
      p_r <- if(n_cat_total > 0) sprintf("%.1f", (n_r / n_cat_total) * 100) else "0.0"
      n_nr <- sum(cat_data$digitally_ready == "Not Ready", na.rm = TRUE)
      p_nr <- if(n_cat_total > 0) sprintf("%.1f", (n_nr / n_cat_total) * 100) else "0.0"
      display_label <- if(!is.null(labels_map)) labels_map[as.character(v)] else v
      
      data.frame(
        Characteristic = paste0("&nbsp;&nbsp;&nbsp;&nbsp;", display_label),
        Ready = paste0(n_r, " (", p_r, "%)"),
        Not_Ready = paste0(n_nr, " (", p_nr, "%)"),
        P_Value = "",
        stringsAsFactors = FALSE
      )
    })
    bind_rows(header, details)
  }
  
  # Calculate Total Row Values
  n_total_ready <- sum(df_table$digitally_ready == "Ready", na.rm = TRUE)
  p_total_ready <- sprintf("%.1f", (n_total_ready / total_n) * 100)
  
  n_total_not <- sum(df_table$digitally_ready == "Not Ready", na.rm = TRUE)
  p_total_not <- sprintf("%.1f", (n_total_not / total_n) * 100)
  
  # Assemble Table 2
  table2_df <- bind_rows(
    data.frame(
      Characteristic = "<b>Total Respondents</b>",
      Ready = paste0(n_total_ready, " (", p_total_ready, "%)"),
      Not_Ready = paste0(n_total_not, " (", p_total_not, "%)"),
      P_Value = "",
      stringsAsFactors = FALSE
    ),
    get_bivariate_row(df_table, "age", "Age (Years)"),
    get_bivariate_row(df_table, "sex", "Sex"),
    get_bivariate_row(df_table, "education_group", "Highest Education Level"),
    get_bivariate_row(df_table, "yrs_experience", "Years of FLCHW Experience"),
    get_bivariate_row(df_table, "daily_hh", "Households Served Daily"),
    get_bivariate_row(df_table, "digital_access", "Digital Access (Work tools)", is_binary = TRUE)
  )
  
  # Render
  datatable(
    table2_df,
    colnames = c("Characteristic", "Ready (N, %)", "Not Ready (N, %)", "Fisher's Exact Test (p-value)"),
    caption = htmltools::tags$caption(
      style = 'caption-side: bottom; text-align: left; font-style: italic; font-size: 12px; color: #555;
      margin-top: 10px;',
      htmltools::HTML(paste0(
        "<b>Note:</b> Percentages are based on N = ", total_n, ". ",
        "In this selection, ", n_missing_ict, " respondent(s) had missing data for all ICT proficiency
        indicators ",
        "and are included in the 'Not Ready' group by default."
      ))
    ),
    escape = FALSE,
    rownames = FALSE,
    selection = 'none',
    options = list(
      dom = 't',
      paging = FALSE,
      ordering = FALSE,
      columnDefs = list(
        list(className = 'dt-left', targets = 0),
        list(className = 'dt-center', targets = 1:3)
      ),
      initComplete = JS("function(settings, json) {
        $(this.api().table().container()).css({
          'font-size': '15.5px', 
          'line-height': '1.3'
        });
        $(this.api().table().body()).find('td').css({
          'padding-top': '2px', 
          'padding-bottom': '2px'});}")
    ),
    class = 'cell-border stripe'
  )
})