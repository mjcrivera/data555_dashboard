# Information and Communication Technology (ICT) Profile
label_lookup <- c(
  access_smartphone          = "Own/Regular access to smartphone",
  access_computer_laptop     = "Own/Regular access to computer/laptop",
  access_internet_connection = "Own/Regular access to internet connection",
  ict_copy_move              = "Copied/Moved files/folders",
  ict_instal_setup           = "Installed or set up software/mobile apps",
  ict_web_search             = "Search using web browser",
  ict_course_training        = "Participated in online course/training",
  ict_create_edit            = "Created/Edited a document",
  ict_social_media           = "Used social media platforms"
)
renderPlotly({
  df_filtered <- shared_flchw$data(withSelection = TRUE)
  radar_base <- df_filtered %>%
    select(any_of(names(label_lookup))) %>%
    summarise(across(everything(), ~ round(mean(. == 1, na.rm = TRUE) * 100, 0))) %>%
    pivot_longer(cols = everything(), names_to = "variable", values_to = "value") %>%
    mutate(
      full_label = label_lookup[variable],
      clean_label = stringr::str_wrap(full_label, width = 20) %>% 
        stringr::str_replace_all("\n", "<br>")
    )
  radar_plot_data <- rbind(radar_base, radar_base[1,])
  radar_plot_data %>%
    plot_ly(
      type = 'scatterpolar',
      r = ~value,
      theta = ~clean_label,
      fill = 'toself',
      mode = 'markers+lines',
      hoverinfo = "text",
      text = ~paste0(clean_label, ": ", value, "%")
    ) %>%
    layout(
      polar = list(
        domain = list(x = c(0.1, 0.9), y = c(0.1, 0.9)),
        radialaxis = list(
          visible = T,
          range = c(0, 100),
          showticklabels = FALSE
        )
      ),
      showlegend = F,
      margin = list(l = 50, r = 50, t = 50, b = 50),
      title = list(
        text = "Workforce ICT Proficiency (%)",
        y = 0.98 
      ),
      font = list(size = 12) 
    )
})

# Workforce Characteristics

renderDT({
  df_table <- shared_flchw$data(withSelection = TRUE)
  total_n <- nrow(df_table)

  core_cols <- c("sex", "age", "daily_hh", "yrs_experience", "education_lvl")
  ict_cols <- names(df_table)[grep("ict_|access_", names(df_table))]
  n_missing <- sum(!complete.cases(df_table[, intersect(names(df_table), c(core_cols, ict_cols))]))

  get_var_rows <- function(data, col_name, label) {
    header <- data.frame(Characteristic = paste0("<b>", label, "</b>"), N_Percent = "", stringsAsFactors = FALSE)
    unique_vals <- if(is.factor(data[[col_name]])) levels(data[[col_name]]) else sort(unique(na.omit(data[[col_name]])))
    details <- map_df(unique_vals, function(v) {
      n_val <- sum(data[[col_name]] == v, na.rm = TRUE)
      p_val <- sprintf("%.1f", (n_val / total_n) * 100)
      data.frame(Characteristic = paste0("&nbsp;&nbsp;&nbsp;&nbsp;", v), N_Percent = paste0(n_val, " (", p_val, "%)"))
    })
    bind_rows(header, details)
  }
  
  get_binary_row <- function(data, col_name, label) {
    n_val <- sum(data[[col_name]] == 1, na.rm = TRUE)
    p_val <- sprintf("%.1f", (n_val / total_n) * 100)
    data.frame(Characteristic = paste0("&nbsp;&nbsp;&nbsp;&nbsp;", label), N_Percent = paste0(n_val, " (", p_val, "%)"))
  }

  summary_df <- bind_rows(
    data.frame(Characteristic = "<b>Total Respondents</b>", N_Percent = as.character(total_n)),
    get_var_rows(df_table, "age", "Age (Years)"),
    get_var_rows(df_table, "sex", "Sex"),
    get_var_rows(df_table, "education_group", "Highest Education Level"),
    get_var_rows(df_table, "yrs_experience", "Years of FLCHW Experience"),
    get_var_rows(df_table, "daily_hh", "Households Served Daily"),
    
    data.frame(Characteristic = "<b>Digital Access*</b>", N_Percent = ""),
    get_binary_row(df_table, "access_smartphone", "Smartphone"),
    get_binary_row(df_table, "access_computer_laptop", "Computer/Laptop"),
    get_binary_row(df_table, "access_internet_connection", "Internet Connection"),
    
    data.frame(Characteristic = "<b>ICT Skills Performed*</b>", N_Percent = ""),
    get_binary_row(df_table, "ict_copy_move", "Copy/Move Files"),
    get_binary_row(df_table, "ict_instal_setup", "Install/Setup Apps"),
    get_binary_row(df_table, "ict_web_search", "Web Browser Search"),
    get_binary_row(df_table, "ict_course_training", "Online Course/Training"),
    get_binary_row(df_table, "ict_create_edit", "Create/Edit Document"),
    get_binary_row(df_table, "ict_social_media", "Social Media Use"),
    
    data.frame(Characteristic = "<b>Professional Development</b>", N_Percent = ""),
    get_binary_row(df_table, "interest_improving", "Interested in Improving Skills")
  )
  
  datatable(
    summary_df,
    colnames = c("Characteristic", "N(%)"),
    caption = htmltools::tags$caption(
      style = 'caption-side: bottom; text-align: left; font-style: italic; font-size: 11px; color: #555; margin-top: 10px;',
      htmltools::HTML(paste0(
        "<b>Note:</b> Percentages are calculated based on the total N of ", total_n, ". ",
        "In this selection, ", n_missing, " respondent(s) had missing data for all ICT proficiency
        indicators.<br>",
        "<b>*</b> Denotes multiple-response categories where respondents could select more than one option; percentages may sum to >100%."
      ))
    ),
    escape = FALSE,
    rownames = FALSE,
    options = list(
      dom = 't',
      paging = FALSE,
      ordering = FALSE,
      columnDefs = list(list(className = 'dt-left', targets = "_all")),
      initComplete = JS("function(settings, json) {
        $(this.api().table().container()).css({
          'font-size': '15px', 
          'line-height': '1.2'
        });
        $(this.api().table().body()).find('td').css({
          'padding-top': '2px', 
          'padding-bottom': '2px'});}")
    ),
    class = 'cell-border stripe'
  )
})

